---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Fariha Hossan',
  description = 'Professional writing portfolio of Fariha Hossan, a Biochemistry and Biotechnology student at North South University and journalist writing on climate, energy, education, and social issues in Bangladesh and South Asia.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <div class="site-bg-art" aria-hidden="true"></div>
    <Navbar />

    <main>
      <slot />
    </main>

    <Footer />

    <div class="image-modal" id="imageModal" aria-hidden="true">
      <button class="modal-backdrop" type="button" data-close-modal aria-label="Close image preview"></button>
      <div class="modal-content" role="dialog" aria-modal="true" aria-label="Article clipping preview">
        <button class="modal-close" type="button" data-close-modal aria-label="Close image preview">×</button>
        <img id="modalImage" src="" alt="Article clipping preview" />
      </div>
    </div>

    <script is:inline>
      const openArticleModal = (trigger) => {
        const modal = document.querySelector('#imageModal');
        const modalImage = document.querySelector('#modalImage');
        if (!trigger || !modal || !modalImage) return;

        const src = trigger.getAttribute('data-zoom-src');
        const alt = trigger.getAttribute('data-zoom-alt') || 'Article clipping preview';
        if (!src) return;

        modalImage.setAttribute('src', src);
        modalImage.setAttribute('alt', alt);
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('modal-open');
      };

      const closeArticleModal = () => {
        const modal = document.querySelector('#imageModal');
        const modalImage = document.querySelector('#modalImage');
        if (!modal || !modalImage) return;

        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        modalImage.setAttribute('src', '');
        document.body.classList.remove('modal-open');
      };

      window.openArticleModal = openArticleModal;

      document.addEventListener('click', (event) => {
        const zoomButton = event.target.closest('[data-open-article], [data-zoom-src]');
        if (zoomButton) {
          event.preventDefault();
          event.stopPropagation();
          openArticleModal(zoomButton);
          return;
        }

        if (event.target.closest('[data-close-modal]')) {
          closeArticleModal();
          return;
        }

        const viewButton = event.target.closest('[data-view]');
        if (viewButton) {
          const targetId = viewButton.getAttribute('data-view-target');
          const view = viewButton.getAttribute('data-view');
          const target = document.querySelector(`#${targetId}`);
          if (target) {
            target.classList.toggle('list-view', view === 'list');
            target.classList.toggle('grid-view', view === 'grid');
            document.querySelectorAll(`[data-view-target="${targetId}"]`).forEach((btn) => {
              btn.classList.toggle('active', btn === viewButton);
            });
          }
        }
      });

      const applyPublicationControls = (targetId) => {
        const target = document.querySelector(`#${targetId}`);
        if (!target) return;

        const yearSelect = document.querySelector(`[data-year-filter="${targetId}"]`);
        const sortSelect = document.querySelector(`[data-sort-control="${targetId}"]`);
        const selectedYear = yearSelect?.value || 'all';
        const sortOrder = sortSelect?.value || 'newest';

        const cards = Array.from(target.querySelectorAll('.publication-card'));
        cards
          .sort((a, b) => {
            const aDate = Number(a.getAttribute('data-date')) || 0;
            const bDate = Number(b.getAttribute('data-date')) || 0;
            return sortOrder === 'oldest' ? aDate - bDate : bDate - aDate;
          })
          .forEach((card) => {
            const cardYear = card.getAttribute('data-year');
            card.hidden = selectedYear !== 'all' && cardYear !== selectedYear;
            target.appendChild(card);
          });
      };

      document.addEventListener('change', (event) => {
        const yearControl = event.target.closest('[data-year-filter]');
        const sortControl = event.target.closest('[data-sort-control]');
        const targetId = yearControl?.getAttribute('data-year-filter') || sortControl?.getAttribute('data-sort-control');
        if (targetId) applyPublicationControls(targetId);
      });

      document.querySelectorAll('[data-controls-for]').forEach((controls) => {
        const targetId = controls.getAttribute('data-controls-for');
        if (targetId) applyPublicationControls(targetId);
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeArticleModal();
      });
    </script>
  </body>
</html>
