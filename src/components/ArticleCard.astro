---
interface Props {
  article: any;
}

const { article } = Astro.props;

const {
  title,
  date,
  category,
  country,
  language,
  newspaper,
  publishedDate,
  summary,
  clipping,
  externalUrl,
} = article.data;

const year = date.getFullYear();
const timestamp = date.valueOf();
const formattedDate = publishedDate || date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const isBangla = language === 'Bangla';
const toBanglaDigits = (value: number | string) =>
  String(value).replace(/\d/g, (digit) => '০১২৩৪৫৬৭৮৯'[Number(digit)]);
const displayYear = isBangla ? toBanglaDigits(year) : String(year);
const originalLabel = isBangla ? 'পত্রিকা লিংক' : 'Paper Link';
const viewArticleLabel = isBangla ? 'লেখা দেখুন' : 'View Article';
---

<article class="publication-card" data-year={year} data-date={timestamp}>
  {clipping && (
    <div class="clipping-wrap" aria-label={`${title} clipping preview`}>
      <img src={clipping} alt={`${title} newspaper clipping`} class="clipping-img" loading="lazy" />
      <button
        class="view-article-chip"
        type="button"
        data-open-article
        data-zoom-src={clipping}
        data-zoom-alt={`${title} newspaper clipping`}
        aria-label={`Open larger view for ${title}`}
      >
        {viewArticleLabel}
      </button>
    </div>
  )}

  <div class="publication-content">
    {externalUrl && (
      <a class="original-link-top" href={externalUrl} target="_blank" rel="noreferrer">
        {originalLabel}
      </a>
    )}

    <div class="pub-tags">
      <span>{category}</span>
      <span>{language === 'Bangla' ? 'বাংলা' : 'English'}</span>
      <span>{displayYear}</span>
    </div>

    <h3>{title}</h3>

    <p class="summary">{summary}</p>

    <div class="pub-meta" aria-label="Publication details">
      {newspaper && (
        <span>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 5.5A2.5 2.5 0 0 1 6.5 3h11A2.5 2.5 0 0 1 20 5.5V19H6.5A2.5 2.5 0 0 1 4 16.5v-11Zm3 1.25h9.5v1.5H7v-1.5Zm0 3h9.5v1.5H7v-1.5Zm0 3h6.5v1.5H7v-1.5Z"/></svg>
          {newspaper}
        </span>
      )}
      <span>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 2h2v2h6V2h2v2h1.5A2.5 2.5 0 0 1 21 6.5v11A2.5 2.5 0 0 1 18.5 20h-13A2.5 2.5 0 0 1 3 17.5v-11A2.5 2.5 0 0 1 5.5 4H7V2Zm12 8H5v7.5c0 .55.45 1 1 1h12c.55 0 1-.45 1-1V10Z"/></svg>
        {formattedDate}
      </span>
      {country && (
        <span>
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm6.5 6h-3.1a15.3 15.3 0 0 0-1.25-3.05A8.05 8.05 0 0 1 18.5 8ZM12 4.1c.72 1.05 1.32 2.36 1.68 3.9h-3.36c.36-1.54.96-2.85 1.68-3.9ZM4.3 14a8.67 8.67 0 0 1 0-4h3.5a17 17 0 0 0 0 4H4.3Zm1.2 2h3.1c.3 1.1.73 2.13 1.25 3.05A8.05 8.05 0 0 1 5.5 16Zm3.1-8H5.5a8.05 8.05 0 0 1 4.35-3.05A15.3 15.3 0 0 0 8.6 8ZM12 19.9c-.72-1.05-1.32-2.36-1.68-3.9h3.36c-.36 1.54-.96 2.85-1.68 3.9ZM14.1 14H9.9a14.4 14.4 0 0 1 0-4h4.2a14.4 14.4 0 0 1 0 4Zm.05 5.05c.52-.92.95-1.95 1.25-3.05h3.1a8.05 8.05 0 0 1-4.35 3.05ZM16.2 14a17 17 0 0 0 0-4h3.5a8.67 8.67 0 0 1 0 4h-3.5Z"/></svg>
          {country}
        </span>
      )}
    </div>

    {(clipping || externalUrl) && (
      <div class="list-article-action">
        {clipping && (
          <button
            class="button small primary"
            type="button"
            data-open-article
            data-zoom-src={clipping}
            data-zoom-alt={`${title} newspaper clipping`}
            aria-label={`Open larger view for ${title}`}
          >
            {viewArticleLabel}
          </button>
        )}

        {externalUrl && (
          <a class="button small list-paper-link" href={externalUrl} target="_blank" rel="noreferrer">
            {originalLabel}
          </a>
        )}
      </div>
    )}
  </div>
</article>
